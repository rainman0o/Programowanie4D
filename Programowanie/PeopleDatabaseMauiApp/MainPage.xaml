<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PeopleDatabaseMauiApp.MainPage"
             xmlns:local ="clr-namespace:PeopleDatabaseMauiApp"
             >

    <ContentPage.BindingContext>
        <local:MainViewModel/>
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Button
                x:Name="getPeople"
                Text="Wyswietl wszyskich ludzi" 
                Command ="{Binding RefreshPeopleCommand}"
                SemanticProperties.Hint="Counts the number of times you click"
                HorizontalOptions="Fill" />
            <Label Text="LISTA OSÓB"
                   FontSize="Large"/>
            <CollectionView ItemsSource="{Binding People}"
                            SelectedItem="{Binding SelectedPerson}"
                            SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Name}"/>
                            <Label Text="{Binding Surname}"/>
                            <Label Text="{Binding Age}"/>
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label
                Text="Modyfikacja wiersza"
                FontSize="Large"/>
            <Label
                Text="Imie"/>
            <Entry
                Text="{Binding SelectedPersonCopy.Name}"/>
            <Label
                Text="Nazwisko"/>
            <Entry
                Text="{Binding SelectedPersonCopy.Surname}"/>
            <Label
                Text="Wiek"/>
            <Entry
                Text="{Binding SelectedPersonCopy.Age}"/>

            <Button Text="Aktualizuj Dane"
                    Command="{Binding UpdatePerson}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

